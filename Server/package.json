{
  "name": "alpha-strike-tracker-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":     "wrangler dev",
    "deploy":  "wrangler deploy",
    "db:migrate:local":  "wrangler d1 migrations apply campaign-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply campaign-db --remote",
    "db:seed:local":     "wrangler d1 execute campaign-db --local  --file=./migrations/0002_seed.sql",
    "db:seed:remote":    "wrangler d1 execute campaign-db --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "bcryptjs":         "^2.4.3",
    "itty-router":      "^5.0.18",
    "jsonwebtoken":     "^9.0.2",
    "uuid":             "^9.0.1"
  },
  "devDependencies": {
    "wrangler": "^3.57.0"
  }
}
